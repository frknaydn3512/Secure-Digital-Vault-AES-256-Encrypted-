<Window x:Class="SecretNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dijital Kasam" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#111827">
    <Grid>

        <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Panel.ZIndex="10">
            <TextBlock Text="🔒 Dijital Kasa" Margin="0,0,0,15" FontSize="26" FontWeight="Bold" Foreground="#F3F4F6" HorizontalAlignment="Center" />
            <PasswordBox x:Name="PasswordInput" Width="250" Height="40" Margin="0,0,0,15" FontSize="16" Padding="8" Background="#374151" Foreground="White" BorderBrush="#4B5563" BorderThickness="1"/>
            <Button x:Name="LoginButton" Content="Kilidi Aç" Width="150" Height="40" FontSize="15" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="LoginButton_Click" Cursor="Hand" FontWeight="SemiBold"/>
            <TextBlock x:Name="ErrorMessage" Text="Hatalı şifre!" Foreground="#F87171" Margin="0,15,0,0" Visibility="Collapsed" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
        </StackPanel>

        <Grid x:Name="VaultPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1F2937" Padding="15" BorderBrush="#374151" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="KASADAKİLER" Foreground="#9CA3AF" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center" />

                    <ListBox x:Name="ItemsListBox" Grid.Row="1" Background="Transparent" Foreground="#F3F4F6" BorderThickness="0" SelectionChanged="ItemsListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="BgBorder" Background="#374151" CornerRadius="6" Padding="12,10">
                                                <ContentPresenter />
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BgBorder" Property="Background" Value="#4B5563" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="BgBorder" Property="Background" Value="#3B82F6" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Baslik}" FontSize="15" Foreground="#E5E7EB" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Button Content="+ Yeni Not Ekle" Height="38" Margin="0,0,0,10" Background="#10B981" Foreground="White" BorderThickness="0" Click="AddNote_Click" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Content="+ Resim/Video Ekle" Height="38" Margin="0,0,0,10" Background="#8B5CF6" Foreground="White" BorderThickness="0" Click="AddMedia_Click" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Content="+ Belge Ekle (PDF, Word)" Height="38" Margin="0,0,0,10" Background="#F59E0B" Foreground="White" BorderThickness="0" Click="AddDocument_Click" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Content="⚙️ Şifre Değiştir" Height="38" Margin="0,0,0,10" Background="#4B5563" Foreground="White" BorderThickness="0" Click="ShowChangePassword_Click" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Content="🔒 Kasayı Kilitle" Height="38" Background="#EF4444" Foreground="White" BorderThickness="0" Click="LockButton_Click" Cursor="Hand" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="TitleTextBox" Grid.Row="0" Text="Başlık Seçin veya Ekleyin" FontSize="22" FontWeight="Bold" Background="Transparent" Foreground="#F3F4F6" BorderThickness="0,0,0,1" BorderBrush="#4B5563" Margin="0,0,0,20" Padding="5" />

                <TextBox x:Name="NoteContentTextBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" FontSize="16" Background="#1F2937" Foreground="#E5E7EB" BorderBrush="#374151" BorderThickness="1" Padding="15" Visibility="Visible" />

                <Image x:Name="ImageViewer" Grid.Row="1" Stretch="Uniform" Visibility="Collapsed" />

                <MediaElement x:Name="VideoPlayer" Grid.Row="1" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="Collapsed" />

                <StackPanel x:Name="DocumentViewerPanel" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📄 Bu gizli bir belge dosyasıdır." Foreground="#E5E7EB" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Button Content="Belgeyi Aç (Görüntüle)" Width="220" Height="45" Background="#F59E0B" Foreground="White" BorderThickness="0" Click="OpenDocument_Click" Cursor="Hand" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="🗑️ Sil" Width="100" Height="45" Margin="0,0,15,0" Background="#EF4444" Foreground="White" BorderThickness="0" Click="DeleteVaultItem_Click" Cursor="Hand" FontSize="15" FontWeight="SemiBold"/>
                    <Button Content="💾 Değişiklikleri Kasaya Kaydet" Width="250" Height="45" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="SaveVault_Click" Cursor="Hand" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Grid>
        <Grid x:Name="ChangePasswordPanel" Visibility="Collapsed" Panel.ZIndex="50">
            <Border Background="Black" Opacity="0.7"/>

            <Border Width="350" Background="#1F2937" CornerRadius="10" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#374151" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⚙️ Şifre Değiştir" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Mevcut Şifreniz" Foreground="#9CA3AF" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="OldPasswordBox" Height="35" Background="#374151" Foreground="White" BorderThickness="0" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Yeni Şifre" Foreground="#9CA3AF" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox" Height="35" Background="#374151" Foreground="White" BorderThickness="0" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Yeni Şifre (Tekrar)" Foreground="#9CA3AF" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmNewPasswordBox" Height="35" Background="#374151" Foreground="White" BorderThickness="0" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock x:Name="ChangePasswordError" Text="Hata mesajı" Foreground="#F87171" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,0,0,15" FontWeight="SemiBold"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="İptal" Height="40" Background="#4B5563" Foreground="White" BorderThickness="0" Click="CancelChangePassword_Click" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Grid.Column="2" Content="Kaydet" Height="40" Background="#10B981" Foreground="White" BorderThickness="0" Click="ConfirmChangePassword_Click" Cursor="Hand" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>